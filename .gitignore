# ============================================
# Go 编译产物
# ============================================
# 编译输出
*.exe
*.exe~
*.dll
*.dylib
*.so
*.dll
*.test
*.out
# 主二进制（多种命名）
/o4openai
/o4openai-test
/server
o4openai-*
!o4openai.spec

# 构建目录
/dist/
/build/

# ============================================
# 依赖管理
# ============================================
# 依赖下载（Go modules 已通过 go.mod/go.sum 跟踪，无需提交）
/vendor/

# ============================================
# 测试与覆盖率
# ============================================
coverage.txt
*.cover
*.coverprofile
htmlcov/

# ============================================
# 配置文件（包含敏感信息）
# ============================================
# 用户特定的 config 副本（保留 config.yaml 示例作为模板）
config.local.yaml
config.prod.yaml
config.*.yaml
!config.yaml

# 环境变量文件
.env
.env.local
.env.*.local
*.env

# ============================================
# 日志
# ============================================
*.log
nohup.out
logs/
*.pid

# ============================================
# 临时文件
# ============================================
*.tmp
*.bak
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
._*

# ============================================
# IDE 与编辑器
# ============================================
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*~

# GoLand
.idea/

# VSCode
.vscode/

# ============================================
# 操作系统
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.directory
.Trash-*

# ============================================
# 容器
# ============================================
# Docker（如果使用 Docker 部署）
# 保留 Dockerfile，但忽略构建产物
*.dockerfile~
docker-compose.override.yml

# ============================================
# 运行时临时数据
# ============================================
# 网关运行时生成的临时图片/缓存
/_temp/
/tmp/
/cache/

# ============================================
# 凭据与密钥
# ============================================
# API Key、Token 等（绝不提交！）
*.key
*.pem
secrets/
credentials/
